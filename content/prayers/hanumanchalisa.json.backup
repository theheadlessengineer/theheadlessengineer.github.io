[
  {
    "verse": "श्री गुरु चरण सरोज रज, निज मन मुकुर सुधार। बरनऊं रघुवर बिमल जसु, जो दायकु फल चार ॥",
    "hindi": "मैं अपने मन दर्पण को श्री गुरु जी की चरण धूलि से पवित्र कर, श्री रघुवीर भगवान के यश का गुणगान करता हूं। जिससे धर्म, अर्थ, काम और मोक्ष की प्राप्ति होती है।"
  },
  {
    "verse": "बुद्धिहीन तनु जानिके, सुमिरौं पवन कुमार। बल बुद्धि विद्या देहु मोहि, हरहु कलेश विकार॥",
    "hindi": "हे पवन पुत्र, मैं आपका स्मरण करता हूं। आप जानते ही हैं कि मेरा शरीर और बुद्धि निर्बल है। मुझे शारीरिक बल, सद्बुद्धि एवं ज्ञान दीजिए और मेरे दुखों व दोषों का नाश कीजिए।"
  },
  {
    "verse": "जय हनुमान ज्ञान गुन सागर। जय कपीस तिहुँ लोक उजागर॥",
    "hindi": "पवनपुत्र वीर हनुमान आपकी जय हो। आप तो ज्ञान और गुणों के समुद्र है। आपकी कीर्ति तो तीनों लोकों में फैली है।"
  },
  {
    "verse": "राम दूत अतुलित बल धामा। अंजनि पुत्र पवनसुत नामा॥",
    "hindi": "हे पवनसुत, अंजनिपुत्र, अंजनीनन्दन, श्री राम दूत, आपके समान दुसरा कोई बलवान नहीं है।"
  },
  {
    "verse": "महाबीर बिक्रम बजरंगी। कुमति निवार सुमति के संगी॥",
    "hindi": "हे महावीर बजरंगबली, आप में विशेष पराक्रम हैं। आप अपने भक्तों की दुर्बुद्धि एवं बुरे विचारों को समाप्त करके, उनके ह्रदय में अच्छे ज्ञान एवं विचारों को प्रेरित करने में सहायक है।।"
  },
  {
    "verse": "कंचन बरन बिराज सुबेसा। कानन कुंडल कुँचित केसा॥",
    "hindi": "आपका रंग कंचन जैसा है, तथा आप सुंदर वस्त्रों से तथा कानों में कुंडल और घुंघराले बालों में शोभायमान है।"
  },
  {
    "verse": "हाथ बज्र औ ध्वजा बिराजे। काँधे मूँज जनेऊ साजे॥",
    "hindi": "आपके हाथों में वज्र और ध्वजा है, तथा आपके कंधे पर मुंज का जनेऊ शोभायमान है।"
  },
  {
    "verse": "शंकर सुवन केसरी नंदन। तेज प्रताप महा जगवंदन॥",
    "hindi": "आप शंकर के अवतार है। सारी संपत्ति आपकी ही तो है, तभी तो आप की उपासना सारा संसार करता है।"
  },
  {
    "verse": "विद्यावान गुनी अति चातुर। राम काज करिबे को आतुर॥",
    "hindi": "आप प्रकांड विद्या निधान और गुणवान हैं। और अत्यंत कार्य कुशल होकर श्री रामजी के कार्य करने के लिए उत्सुक रहते हैं।"
  },
  {
    "verse": "प्रभु चरित्र सुनिबे को रसिया। राम लखन सीता मनबसिया॥",
    "hindi": "श्री राम का गुणगान सुनने में आप आनंद रस लेते हैं। भगवान श्री राम, माता सीता व लक्ष्मण सहित आपके हृदय में निवास करते हैं।"
  },
  {
    "verse": "सूक्ष्म रूप धरी सियहिं दिखावा। बिकट रूप धरि लंक जरावा||",
    "hindi": "आपने अति छोटा रूप धारण कर माता सीता को दिखाया, तथा भयंकर रूप धारण कर रावण की लंका को जलाया।"
  },
  {
    "verse": "भीम रूप धरि असुर सँहारे। रामचन्द्र के काज सँवारे॥",
    "hindi": "आपने विशाल रूप धारण करके राक्षसों का वध किया। भगवान राम के कार्यों में सहयोग देने वाले भी तो आप ही थे।"
  },
  {
    "verse": "लाय सजीवन लखन जियाए। श्री रघुबीर हरषि उर लाए॥",
    "hindi": "संजीवनी बूटी लाकर आपने लक्ष्मण जी को जीवनदान दिया, अतः श्री राम ने प्रसन्न होकर आपको हृदय से लगा लिया।"
  },
  {
    "verse": "रघुपति कीन्हीं बहुत बड़ाई। तुम मम प्रिय भरतहि सम भाई॥",
